<Window x:Class="DemoExam3.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="520" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Группа полей -->
        <GroupBox Header="Данные о партнере" Grid.Row="0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Наименование -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtPartnerName" Margin="0,5,0,5" Padding="5,3"/>

                <!-- Тип партнера -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип партнера:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbPartnerType" Margin="0,5,0,5" Padding="5,3" DisplayMemberPath="PartnerType"/>

                <!-- Рейтинг -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Рейтинг:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtRating" Margin="0,5,0,5" Padding="5,3"/>

                <!-- Адрес -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Адрес:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtAddress" Margin="0,5,0,5" Padding="5,3"/>

                <!-- ФИО директора -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="ФИО директора:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtDirector" Margin="0,5,0,5" Padding="5,3"/>

                <!-- Телефон -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtPhone" Margin="0,5,0,5" Padding="5,3"/>

                <!-- Email -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtEmail" Margin="0,5,0,5" Padding="5,3"/>
            </Grid>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>